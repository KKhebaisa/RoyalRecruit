# ── Discord Application ───────────────────────────────────────────────────────
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/callback

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_strong_password

# ── Security ──────────────────────────────────────────────────────────────────
# Generate JWT secret:     python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=change_this_to_a_secure_random_string

# Generate Fernet key:     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# Generate API secret:     python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change_this_internal_api_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://yourdomain.com"]

# ── Discord Bot Listing ───────────────────────────────────────────────────────
# top.gg token for auto-posting guild count (optional)
TOPGG_TOKEN=

# Your Discord support server invite link (required for most listing sites)
SUPPORT_SERVER_URL=https://discord.gg/your_invite

# Hosted privacy policy URL (required for Discord bot listing)
PRIVACY_POLICY_URL=https://yourdomain.com/privacy

# Bot invite URL from Discord Developer Portal → OAuth2 → URL Generator
BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_ID&permissions=536879120&scope=bot+applications.commands

# ── Development only ──────────────────────────────────────────────────────────
# Set to your dev guild ID for instant slash command sync (omit in production)
DEV_GUILD_ID=

# Set to "development" to enable /docs and /redoc on the API
ENVIRONMENT=production
